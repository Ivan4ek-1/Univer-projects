#include <iostream>
#include <vector>
#include <queue>
#include <cstdlib>
#include <ctime>
using namespace std;

struct BST {
    struct N {
        int v;
        N *l,*r;
        N(int v):v(v),l(0),r(0){}
    }*r=0;

    N* ins(N* t,int v){
        if(!t) return new N(v);
        if(v<t->v) t->l=ins(t->l,v);
        else t->r=ins(t->r,v);
        return t;
    }

    void add(int v){ r=ins(r,v); }

    int h(N* t){
        if(!t) return 0;
        return 1+max(h(t->l),h(t->r));
    }

    void print(){
        int height=h(r);
        if(!r) return;

        queue<N*> q;
        q.push(r);

        int level=0;
        int maxNodes=1<<height;

        while(level<height){
            int sz=q.size();
            int space=maxNodes>>(level+1);

            for(int i=0;i<sz;i++){
                for(int j=0;j<space;j++) cout<<" ";
                N* cur=q.front(); q.pop();

                if(cur){
                    cout<<cur->v;
                    q.push(cur->l);
                    q.push(cur->r);
                } else {
                    cout<<" ";
                    q.push(0);
                    q.push(0);
                }

                for(int j=0;j<space;j++) cout<<" ";
            }
            cout<<"\n";

            for(int i=0;i<sz;i++){
                for(int j=0;j<space;j++) cout<<" ";
                N* cur=q.front();

                if(cur){
                    cout<<(cur->l?"/":" ");
                    cout<<" ";
                    cout<<(cur->r?"\\":" ");
                } else {
                    cout<<"   ";
                }

                for(int j=0;j<space;j++) cout<<" ";
                q.push(q.front()); q.pop();
            }
            cout<<"\n";

            level++;
        }
    }
};

int main(){
    int N,in;
    cin>>N>>in;

    vector<int>a(N);
    if(in==1){
        for(int i=0;i<N;i++) cin>>a[i];
    } else {
        srand(time(0));
        for(int i=0;i<N;i++){
            a[i]=rand()%N+1;
            cout<<a[i]<<" ";
        }
        cout<<"\n";
    }

    BST t;
    for(int x:a) t.add(x);

    t.print();
}
