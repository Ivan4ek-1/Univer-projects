using namespace std;

struct BST {
    struct N {
        int v;
        N* l, * r;
        N(int v) : v(v), l(0), r(0) {}
    };

    N* r = 0;

    N* ins(N* t, int v) {
        if (!t) return new N(v);
        if (v < t->v) t->l = ins(t->l, v);
        else t->r = ins(t->r, v);
        return t;
    }

    void add(int v) {
        r = ins(r, v);
    }

    int h(N* t) {
        if (!t) return 0;
        return 1 + max(h(t->l), h(t->r));
    }

    struct Item {
        N* n;
        int x;
        int y;
    };

    void print() {
        if (!r) return;

        int H = h(r);
        int width = 80;

        vector<vector<char>> grid(H * 2 + 1, vector<char>(width, ' '));

        queue<Item> q;
        q.push({ r, width / 2, 0 });

        while (!q.empty()) {
            Item cur = q.front(); q.pop();

            int x = cur.x;
            int y = cur.y;

            if (x < 0 || x >= width || y >= H * 2) continue;

            string s = "[" + to_string(cur.n->v) + "]";
            int node_width = s.length();
            int start_x = max(0, min(width - node_width, x - node_width / 2));

            for (int i = 0; i < node_width && start_x + i < width; i++) {
                grid[y][start_x + i] = s[i];
            }

            int offset = max(2, (width / 4) >> (cur.y / 2));

            if (cur.n->l) {
                int left_x = max(0, start_x - offset);
                grid[y + 1][left_x] = '/';
                q.push({ cur.n->l, left_x, y + 2 });
            }

            if (cur.n->r) {
                int right_x = min(width - 1, start_x + node_width + offset);
                grid[y + 1][right_x - 1] = '\\';
                q.push({ cur.n->r, right_x, y + 2 });
            }
        }

        for (auto& row : grid) {
            bool empty = true;
            for (char c : row) if (c != ' ') { empty = false; break; }
            if (!empty) {
                for (char c : row) cout << c;
                cout << "\n";
            }
        }
    }
};

struct BTree {
    struct N {
        vector<int> k;
        vector<N*> c;
        bool leaf;
        N(bool l) : leaf(l) {}
    };

    N* r = 0;
    int t;

    BTree(int t) : t(t) {}

    void split(N* x, int i) {
        N* y = x->c[i];
        N* z = new N(y->leaf);

        int mid = y->k[t - 1];

        for (int j = t; j < y->k.size(); j++)
            z->k.push_back(y->k[j]);

        if (!y->leaf)
            for (int j = t; j < y->c.size(); j++)
                z->c.push_back(y->c[j]);

        y->k.resize(t - 1);
        if (!y->leaf) y->c.resize(t);

        x->c.insert(x->c.begin() + i + 1, z);
        x->k.insert(x->k.begin() + i, mid);
    }

    void insNF(N* x, int v) {
        int i = x->k.size() - 1;

        if (x->leaf) {
            x->k.push_back(0);
            while (i >= 0 && v < x->k[i]) {
                x->k[i + 1] = x->k[i];
                i--;
            }
            x->k[i + 1] = v;
        }
        else {
            while (i >= 0 && v < x->k[i]) i--;
            i++;

            if (x->c[i]->k.size() == 2 * t - 1) {
                split(x, i);
                if (v > x->k[i]) i++;
            }

            insNF(x->c[i], v);
        }
    }

    void add(int v) {
        if (!r) {
            r = new N(true);
            r->k.push_back(v);
            return;
        }

        if (r->k.size() == 2 * t - 1) {
            N* s = new N(false);
            s->c.push_back(r);
            split(s, 0);

            int i = (v > s->k[0]);
            insNF(s->c[i], v);

            r = s;
        }
        else {
            insNF(r, v);
        }
    }

    int getHeight(N* node) {
        if (!node || node->leaf) return 0;
        int max_h = 0;
        for (auto child : node->c) {
            max_h = std::max(max_h, getHeight(child));  
        }
        return 1 + max_h;
    }

    struct PrintItem {
        N* node;
        int x;
        int y;
    };

    void print() {
        if (!r) return;

        int H = getHeight(r);
        int width = 140;

        vector<vector<char>> grid(H * 4 + 2, vector<char>(width, ' '));

        queue<PrintItem> q;
        q.push({ r, width / 2, 0 });

        while (!q.empty()) {
            PrintItem cur = q.front(); q.pop();

            int x = cur.x;
            int y = cur.y * 4;

            if (x < 0 || x >= width || y >= H * 4) continue;

            string keys;
            for (size_t i = 0; i < cur.node->k.size(); ++i) {
                keys += to_string(cur.node->k[i]);
                if (i + 1 < cur.node->k.size()) keys += " ";
            }
            string s = "[" + keys + "]";

            int node_width = s.length();
            int start_x = std::max(1, std::min(width - node_width - 1, x - node_width / 2));  

            for (int i = 0; i < node_width && start_x + i < width; ++i) {
                grid[y][start_x + i] = s[i];
            }

            if (!cur.node->leaf && !cur.node->c.empty()) {
                int num_children = cur.node->c.size();
                int total_offset = (width - 20) / (num_children + 1);
                int base_offset = total_offset / 2;

                for (int i = 0; i < num_children; ++i) {
                    if (cur.node->c[i]) {
                        int child_x = std::max(1, std::min(width - 10,
                            start_x + static_cast<int>((i - (num_children - 1) / 2.0f) * base_offset)));

                        int branch_start = std::min(x + node_width / 2, std::max(start_x, child_x));
                        int branch_end = std::max(x + node_width / 2, std::min(start_x + node_width, child_x));

                        if (child_x < start_x) {
                            grid[y + 1][branch_start] = '/';
                        }
                        else if (child_x > start_x + node_width) {
                            grid[y + 1][branch_end - 1] = '\\';
                        }

                        q.push({ cur.node->c[i], child_x, cur.y + 1 });
                    }
                }
            }
        }

        for (auto& row : grid) {
            bool empty = true;
            for (char c : row) if (c != ' ') { empty = false; break; }
            if (!empty) {
                for (char c : row) cout << c;
                cout << "\n";
            }
        }
        cout << "\n";
    }
};

int main() {
    int mode, N, in;

    cout << "1-BST 2-BTree: ";
    cin >> mode;

    cout << "N: ";
    cin >> N;

    cout << "1-manual 2-random: ";
    cin >> in;

    vector<int> a(N);

    if (in == 1) {
        for (int i = 0; i < N; i++) cin >> a[i];
    }
    else {
        srand(time(0));
        for (int i = 0; i < N; i++) {
            a[i] = rand() % (N * 2) + 1;
            cout << a[i] << " ";
        }
        cout << "\n";
    }

    if (mode == 1) {
        BST t;
        for (int x : a) t.add(x);
        cout << "\nBST:\n";
        t.print();
    }
    else {
        int tdeg;
        cout << "t: ";
        cin >> tdeg;
        BTree t(tdeg);
        for (int x : a) t.add(x);
        cout << "\nBTree (t=" << tdeg << "):\n";
        t.print();
    }

    return 0;
}
