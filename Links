#include <iostream>
#include <string>
#include <map>
using namespace std;

struct Task {
	int id;
	int value;
	Task* prev;
	Task* next;
};

map<int, Task*> mp;
Task* head = nullptr;
Task* tail = nullptr;

void add(int id, int value) {
	Task* x = new Task{ id, value, nullptr, nullptr };

	mp[id] = x;

	if (!head) {
		head = tail = x;
		return;
	}

	tail->next = x;
	x->prev = tail;
	tail = x;

}

void insert_after(int target_id, int new_id, int value) {
	Task* pos = mp[target_id];
	Task* x = new Task{ new_id, value, nullptr, nullptr };

	mp[new_id] = x;

	x->next = pos->next;
	x->prev = pos;

	if (pos->next)
		pos->next->prev = x;
	else
		tail = x;

	pos->next = x;
}

void move_to_front(int id) {
	Task* x = mp[id];

	if (x == head) return;

	detach(x);

	x->prev = nullptr;
	x->next = head;

	head->prev = x;
	head = x;
}

void splice_range(int id_from, int id_to) {
	Task* L = mp[id_from];
	Task* R = mp[id_to];

	if (L == head) return;

	Task* before = L->prev;
	Task* after = R->next;

	if (before) before->next = after;
	else head = after;

	if (after) after->prev = before;
	else tail = before;

	R->next = head;
	L->prev = nullptr;

	if (head) head->prev = R;
	head = L;
}

void remove(int id) {
	Task* x = mp[id];

	detach(x);

	mp.erase(id);
	delete x;
}


