#include <iostream>
#include <map>
using namespace std;

struct Task {
	int id;
	int value;
	Task* prev;
	Task* next;
};

map<int, Task*> mp;
Task* head = nullptr;
Task* tail = nullptr;

void detach(Task* x) {
	if (x->prev)
		x->prev->next = x->next; //отбирнаем связь предыдущего к х и менем ее на связь предфдущий-слоедующий
	else
		head = x->next;

	if (x->next)
		x->next->prev = x->prev;
	else
		tail = x->prev;

	x->prev = nullptr;
	x->next = nullptr;
}

void add(int id, int value) {
	Task* x = new Task{ id, value, nullptr, nullptr };

	mp[id] = x;

	if (!head) {
		head = tail = x;
		return;
	}

	tail->next = x;
	x->prev = tail;
	tail = x;

}

void insert_after(int target_id, int new_id, int value) {
	Task* pos = mp[target_id];
	Task* x = new Task{ new_id, value, nullptr, nullptr };

	mp[new_id] = x;

	x->next = pos->next;
	x->prev = pos;

	if (pos->next)
		pos->next->prev = x;
	else
		tail = x;

	pos->next = x;
}

void move_to_front(int id) {
	Task* x = mp[id];

	if (x == head) return;

	detach(x);

	x->prev = nullptr;
	x->next = head;

	head->prev = x;
	head = x;
}

void splice_range(int id_from, int id_to) {
	Task* L = mp[id_from];
	Task* R = mp[id_to];

	if (L == head) return;

	Task* before = L->prev;
	Task* after = R->next;

	if (before) before->next = after;
	else head = after;

	if (after) after->prev = before;
	else tail = before;

	R->next = head;
	L->prev = nullptr;

	if (head) head->prev = R;
	head = L;
}

void remove(int id) {
	Task* x = mp[id];

	detach(x);

	mp.erase(id);
	delete x;
}

int get_value(int id) {
	return mp.at(id)->value;
}

void see_map() {
	for (auto it = mp.begin(); it != mp.end(); it++) {
		cout << it->first << " " << it->second->value << "\n";
	}
}


int main() {
	cout << "Insert how many commands\n";
	int n;
	cin >> n;
	cout << "Now insert commands\n";

	for (int i = 0; i < n; i++) {
		string cmd;
		cin >> cmd;

		if (cmd == "add") {
			int id, value;
			cin >> id >> value;
			add(id, value);
		}

		else if (cmd == "insert_after") {
			int target_id, new_id, value;
			cin >> target_id >> new_id >> value;
			insert_after(target_id, new_id, value);
		}

		else if (cmd == "move_to_front") {
			int id;
			cin >> id;
			move_to_front(id);
		}

		else if (cmd == "splice_range") {
			int l, r;
			cin >> l >> r;
			splice_range(l, r);
		}

		else if (cmd == "get_value") {
			int id;
			cin >> id;
			cout << get_value(id) << "\n";
		}

		else if (cmd == "remove") {
			int id;
			cin >> id;
			remove(id);
		}

		else if (cmd == "see_map") {
			see_map();
		}
	}

	return 0;
}

