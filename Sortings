void writeToFile(const vector<int>& arr, const string& filename) {
    char* userProfile = getenv("USERPROFILE");
    string desktopPath = "";

    if (userProfile != NULL) {
        desktopPath = string(userProfile) + "\\Desktop\\";
    }
    else {
       
        desktopPath = "";
    }

    string fullPath = desktopPath + filename;

    ofstream file(fullPath);
    if (file.is_open()) {
        for (int i = 0; i < arr.size(); i++) {
            file << arr[i];
            if (i < arr.size() - 1) file << ", ";
        }
        file.close();
        cout << " Файл сохранён: " << fullPath << endl;
    }
    else {
        cout << " Ошибка создания файла: " << fullPath << endl;
    }
}

// выбор опорного элемента
int choice3(vector<int> arr) {
    int len = arr.size();
    int first = arr[0], mid = arr[len / 2], last = arr[len - 1];

    if ((first > mid) != (first > last))
        return first;
    if ((mid > first) != (mid > last))
        return mid;
    return last;
}

vector<int> readFile(string filename) {
    ifstream file(filename);
    string line;
    getline(file, line);

    for (int i = 0; i < line.length(); i++) {
        if (line[i] == '{' || line[i] == '}' || line[i] == ',') {
            line[i] = ' ';
        }
    }

    stringstream ss(line); // создание потока из строки
    vector<int> vec;
    int num;
    while (ss >> num) {
        vec.push_back(num);
    }

    return vec;
}

vector<int> quicksort(vector<int> arr) {
    if (arr.size() < 2) {
        return arr;
    }
    if (arr.size() == 2) {
        if (arr[0] > arr[1]) { // сложность: сравнение
            int temp_val = arr[0];
            arr[0] = arr[1];
            arr[1] = temp_val; // сложность: перестановка
        }
        return arr;
    }

    vector<int> new_arr = {}, less_op = {}, bigger_op = {};
    int opor = choice3(arr);
    int op_cnt = 0;

    for (int i = 0; i < arr.size(); i++) {
        if (arr[i] < opor) { // сложность: сравнение
            less_op.push_back(arr[i]);
        }
        if (arr[i] > opor) {
            bigger_op.push_back(arr[i]);
        }
        if (arr[i] == opor) {
            op_cnt++;
        }
    }

    less_op = quicksort(less_op);
    bigger_op = quicksort(bigger_op);

    new_arr = less_op;
    for (int i = 0; i < op_cnt; i++)
        new_arr.push_back(opor);
    new_arr.insert(new_arr.end(), bigger_op.begin(), bigger_op.end());
    return new_arr;
}

vector<int> insertsort(vector<int> arr) {
    for (int i = 1; i < arr.size(); i++) {
        int key = arr[i];
        int prev_key = i - 1;
        while (prev_key >= 0 && arr[prev_key] > key) { // сложность: сравнение
            arr[prev_key + 1] = arr[prev_key]; // сложность: перестановка
            prev_key--;
        }
        arr[prev_key + 1] = key; // сложность: перестановка
    }
    return arr;
}

vector<int> countsort(vector<int> arr) {
    if (arr.empty())
        return arr;

    int maxim = *max_element(arr.begin(), arr.end());
    int minim = *min_element(arr.begin(), arr.end());
    int range = maxim - minim + 1;
    vector<int> countarr(range, 0); // вектор размера range, заполненный нулями
    vector<int> victor;

    for (int i = 0; i < arr.size(); i++) { // заполнение вектора количествами чисел
        countarr[arr[i] - minim]++;
    }

    for (int i = 0; i < range; i++) { // сложность: восстановление массива
        while (countarr[i] > 0) {
            victor.push_back(i + minim);
            countarr[i]--;
        }
    }
    return victor;
}

vector<int> shakersort(vector<int> arr) {
    int left = 0;
    int right = arr.size() - 1;
    bool swapped = true;

    while (left < right&& swapped) {
        swapped = false;

        for (int i = left; i < right; i++) { // слева направо
            if (arr[i] > arr[i + 1]) { // сложность: сравнение
                swap(arr[i], arr[i + 1]); // сложность: перестановка
                swapped = true;
            }
        }
        right--;

        for (int i = right; i > left; i--) { // справа налево
            if (arr[i] < arr[i - 1]) { // сложность: сравнение
                swap(arr[i], arr[i - 1]); // сложность: перестановка
                swapped = true;
            }
        }
        left++;
    }

    return arr;
}

vector<int> radixsort(vector<int> arr) {
    for (int exp = 1; exp <= 100; exp *= 10) {
        vector<vector<int>> buckets(10);

        for (int i = 0; i < arr.size(); i++) { // сложность: распределение по корзинам
            int digit = (arr[i] / exp) % 10; // берём разряд, по которому сортируем
            buckets[digit].push_back(arr[i]);
        }

        int index = 0;
        for (int i = 0; i < 10; i++) { // сложность: восстановление массива
            for (int j = 0; j < buckets[i].size(); j++) {
                int num = buckets[i][j];
                arr[index] = num;
                index++;
            }
        }
    }
    return arr;
}

